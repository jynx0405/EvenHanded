{
  "manifest_version": 3,
  "name": "Even Handed",
  "version": "1.0.0",
  "description": "Compare how different news outlets frame the same story.",
  "permissions": ["activeTab", "tabs"],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Even Handed"
  },
  "host_permissions": [
    "http://localhost:8000/*"
  ]
}